{
  "datasets": [
    {
      "name": "kpis",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT   SUM(total_price) AS revenue,   COUNT(*) AS orders,   AVG(total_price) AS avg_ticket,   COUNT(DISTINCT franchise_id) AS franchises FROM silver_transactions"
      ],
      "catalog": "workspace",
      "schema": "mateusvbkasuya_test"
    },
    {
      "name": "daily_revenue",
      "displayName": "Daily revenue",
      "queryLines": [
        "SELECT transaction_date, SUM(revenue) AS revenue FROM gold_daily_sales_by_franchise GROUP BY transaction_date ORDER BY transaction_date"
      ],
      "catalog": "workspace",
      "schema": "mateusvbkasuya_test"
    },
    {
      "name": "by_product",
      "displayName": "Revenue by product",
      "queryLines": [
        "SELECT product, revenue, units_sold FROM gold_sales_by_product ORDER BY revenue DESC"
      ],
      "catalog": "workspace",
      "schema": "mateusvbkasuya_test"
    },
    {
      "name": "by_country",
      "displayName": "Revenue by country",
      "queryLines": [
        "SELECT   country,   CASE WHEN country = 'USA' THEN 'United States' ELSE country END AS country_map_name,   revenue,   orders FROM gold_sales_by_country ORDER BY revenue DESC"
      ],
      "catalog": "workspace",
      "schema": "mateusvbkasuya_test"
    },
    {
      "name": "payment_mix",
      "displayName": "Payment mix",
      "queryLines": [
        "SELECT payment_method, COUNT(*) AS orders, SUM(total_price) AS revenue FROM silver_transactions GROUP BY payment_method ORDER BY orders DESC"
      ],
      "catalog": "workspace",
      "schema": "mateusvbkasuya_test"
    },
    {
      "name": "franchise_perf",
      "displayName": "Franchise ranking",
      "queryLines": [
        "SELECT franchise_name, franchise_city, franchise_country, revenue, orders, avg_ticket FROM gold_franchise_performance ORDER BY revenue DESC LIMIT 15"
      ],
      "catalog": "workspace",
      "schema": "mateusvbkasuya_test"
    },
    {
      "name": "sentiment",
      "displayName": "Review sentiment",
      "queryLines": [
        "SELECT sentiment, COUNT(*) AS review_count FROM silver_reviews_sentiment GROUP BY sentiment ORDER BY review_count DESC"
      ],
      "catalog": "workspace",
      "schema": "mateusvbkasuya_test"
    }
  ],
