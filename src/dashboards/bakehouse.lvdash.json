{
  "datasets": [
    {
      "name": "kpis",
      "displayName": "KPIs gerais",
      "queryLines": [
        "SELECT ",
        "  SUM(total_revenue) AS total_revenue, ",
        "  SUM(total_orders) AS total_orders, ",
        "  ROUND(SUM(total_revenue) / SUM(total_orders), 2) AS avg_ticket, ",
        "  COUNT(DISTINCT franchise_id) AS active_franchises ",
        "FROM daily_sales_by_franchise"
      ]
    },
    {
      "name": "daily_revenue",
      "displayName": "Receita diária",
      "queryLines": [
        "SELECT ",
        "  sale_date, ",
        "  SUM(total_revenue) AS total_revenue, ",
        "  SUM(total_orders) AS total_orders ",
        "FROM daily_sales_by_franchise ",
        "GROUP BY sale_date ",
        "ORDER BY sale_date"
      ]
    },
    {
      "name": "by_product",
      "displayName": "Receita por produto",
      "queryLines": [
        "SELECT ",
        "  product, ",
        "  total_revenue, ",
        "  total_units, ",
        "  total_orders, ",
        "  avg_ticket, ",
        "  revenue_pct / 100 AS revenue_share ",
        "FROM sales_by_product ",
        "ORDER BY total_revenue DESC"
      ]
    },
    {
      "name": "payment_mix",
      "displayName": "Mix de meio de pagamento",
      "queryLines": [
        "SELECT ",
        "  payment_method, ",
        "  SUM(total_revenue) AS total_revenue, ",
        "  SUM(total_orders) AS total_orders ",
        "FROM daily_sales_by_franchise ",
        "GROUP BY payment_method ",
        "ORDER BY total_revenue DESC"
      ]
    },
    {
      "name": "franchise_map",
      "displayName": "Franquias (geo)",
      "queryLines": [
        "SELECT ",
        "  franchise_name, ",
        "  city, ",
        "  country, ",
        "  latitude, ",
        "  longitude, ",
        "  total_revenue, ",
        "  total_orders ",
        "FROM franchise_performance ",
        "ORDER BY total_revenue DESC"
      ]
    },
    {
      "name": "franchise_ranking",
      "displayName": "Ranking de franquias",
      "queryLines": [
        "SELECT ",
        "  franchise_name, ",
        "  city, ",
        "  country, ",
        "  total_revenue, ",
        "  total_orders, ",
        "  avg_ticket, ",
        "  revenue_rank ",
        "FROM franchise_performance ",
        "ORDER BY revenue_rank ",
        "LIMIT 10"
      ]
    },
    {
      "name": "by_country",
      "displayName": "Receita por país",
      "queryLines": [
        "SELECT ",
        "  country, ",
        "  total_revenue, ",
        "  total_orders, ",
        "  active_franchises, ",
        "  avg_ticket, ",
        "  revenue_pct / 100 AS revenue_share ",
        "FROM sales_by_country ",
        "ORDER BY total_revenue DESC"
      ]
    },
    {
      "name": "sentiment_distribution",
      "displayName": "Distribuição de sentimento",
      "queryLines": [
        "SELECT 'Positivo' AS sentiment, SUM(positive_reviews) AS reviews FROM sentiment_by_franchise ",
        "UNION ALL SELECT 'Negativo', SUM(negative_reviews) FROM sentiment_by_franchise ",
        "UNION ALL SELECT 'Neutro', SUM(neutral_reviews) FROM sentiment_by_franchise ",
        "UNION ALL SELECT 'Misto', SUM(mixed_reviews) FROM sentiment_by_franchise ",
        "ORDER BY reviews DESC"
      ]
    },
    {
      "name": "sentiment_franchise",
      "displayName": "Sentimento por franquia",
      "queryLines": [
        "SELECT ",
        "  franchise_name, ",
        "  city, ",
        "  country, ",
        "  total_reviews, ",
        "  positive_reviews, ",
        "  negative_reviews, ",
        "  mixed_reviews, ",
        "  positive_pct / 100 AS positive_share, ",
        "  negative_pct / 100 AS negative_share ",
        "FROM sentiment_by_franchise ",
        "ORDER BY negative_share DESC, total_reviews DESC"
      ]
    },
    {
      "name": "sentiment_worst",
      "displayName": "Franquias com mais reviews negativos",
      "queryLines": [
        "SELECT ",
        "  franchise_name, ",
        "  country, ",
        "  negative_pct / 100 AS negative_share, ",
        "  total_reviews ",
        "FROM sentiment_by_franchise ",
        "WHERE total_reviews >= 3 ",
        "ORDER BY negative_share DESC, total_reviews DESC ",
        "LIMIT 10"
      ]
    },
    {
      "name": "top_customers",
      "displayName": "Melhores clientes",
      "queryLines": [
        "SELECT ",
        "  customer_name, ",
        "  country, ",
        "  total_orders, ",
        "  total_revenue, ",
        "  avg_ticket, ",
        "  revenue_rank ",
        "FROM top_customers ",
        "ORDER BY revenue_rank ",
        "LIMIT 15"
      ]
    }
  ],
